---
import "../styles/globals.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SEO from "../components/SEO.astro";
import { ClientRouter } from "astro:transitions";
import { PORTFOLIO } from "../data/portfolio";

export interface Props {
    title?: string;
    description?: string;
    pageType?: "WebSite" | "ProfilePage" | "WebPage";
    image?: string;
    noindex?: boolean;
    bare?: boolean;
}

const { title, description, pageType, image, noindex, bare } = Astro.props;
const bodyClass = bare ? undefined : "pb-[calc(5.5rem+env(safe-area-inset-bottom))] sm:pb-0";
const { site, profile, socialLinks } = PORTFOLIO;
const assetOrigins = Array.from(
    new Set(
        [profile.avatar, profile.ogImage, ...socialLinks.map((link) => link.icon)]
            .filter((value) => value.startsWith("http"))
            .map((value) => new URL(value).origin),
    ),
);
---

<!doctype html>
<html lang={site.language}>
    <head>
        <meta charset="UTF-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1.0, viewport-fit=cover"
        />
        <meta name="generator" content={Astro.generator} />
        <meta name="color-scheme" content="dark light" />
        <meta
            name="theme-color"
            media="(prefers-color-scheme: light)"
            content={site.themeColor.light}
        />
        <meta
            name="theme-color"
            media="(prefers-color-scheme: dark)"
            content={site.themeColor.dark}
        />
        <meta name="format-detection" content="telephone=no" />

        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" type="image/x-icon" href="/favicon.ico" />
        <link rel="apple-touch-icon" href="/apple-icon.png" />
        <link rel="manifest" href="/manifest.webmanifest" />

        <!-- Preconnect to configured remote assets -->
        {
            assetOrigins.map((origin) => (
                <>
                    <link rel="preconnect" href={origin} crossorigin />
                    <link rel="dns-prefetch" href={origin} />
                </>
            ))
        }

        <!-- AI / LLM discoverability -->
        <link
            rel="alternate"
            type="text/plain"
            href="/llms.txt"
            title="LLM-friendly site summary"
        />
        <link
            rel="alternate"
            type="text/plain"
            href="/llms-full.txt"
            title="Full LLM-friendly site content"
        />

        <!-- Prevent FOUC: set theme before paint -->
        <script is:inline>
            (function () {
                try {
                    var stored = localStorage.getItem("theme");
                    var theme = stored || "dark";
                    if (theme === "dark")
                        document.documentElement.classList.add("dark");
                    else document.documentElement.classList.remove("dark");
                } catch (e) {
                    document.documentElement.classList.add("dark");
                }
            })();
        </script>

        <SEO
            title={title}
            description={description}
            pageType={pageType}
            image={image}
            noindex={noindex}
        />

        <ClientRouter />
    </head>
    <body class={bodyClass}>
        <a
            href="#main-content"
            class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:bg-background focus:text-foreground focus:border focus:border-border focus:px-3 focus:py-2 focus:rounded-md"
        >
            Skip to main content
        </a>
        {!bare && <SiteHeader />}
        <slot />
        {!bare && <SiteFooter />}
    </body>
</html>
