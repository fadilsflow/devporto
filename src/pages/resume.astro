---
import Layout from "../layouts/Layout.astro";
import Panel from "../components/Panel.astro";
import { PORTFOLIO } from "../data";

const { resume } = PORTFOLIO;
---

<Layout
    title={resume.title}
    description={resume.seoDescription}
    pageType="WebPage"
>
    <main id="main-content" class="mx-auto max-w-3xl px-2">
        <div class="max-w-screen overflow-x-hidden">
            <div class="pt-2">
                <h1 class="text-3xl font-semibold">{resume.title}</h1>
            </div>

            <div class="py-4">
                <p class="font-mono text-sm text-balance text-muted-foreground">
                    {resume.description}
                </p>
            </div>

            <Panel>
                <div class="relative pt-4">
                    <div
                        class="absolute inset-0 -z-1 grid grid-cols-1 gap-4 max-sm:hidden sm:grid-cols-2"
                    >
                        <div class="border-r border-edge"></div>
                        <div class="border-l border-edge"></div>
                    </div>

                    {resume.embedUrl ? (
                        <iframe
                            src={resume.embedUrl}
                            allow="autoplay"
                            title={`${resume.title} PDF preview`}
                            loading="lazy"
                            class="h-[1000px] w-full"></iframe>
                    ) : (
                        <div class="flex min-h-80 flex-col items-center justify-center gap-3 px-4 text-center text-muted-foreground">
                            <p>Add a resume embed URL in <code>src/data/portfolio.ts</code>.</p>
                            {resume.downloadUrl && (
                                <a class="link" href={resume.downloadUrl} target="_blank" rel="noopener noreferrer">
                                    Download resume
                                </a>
                            )}
                        </div>
                    )}
                </div>

                <div class="h-4"></div>
            </Panel>
        </div>
    </main>
</Layout>
