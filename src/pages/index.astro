---
import Layout from "../layouts/Layout.astro";
import ProfileHeader from "../components/ProfileHeader.astro";
import Overview from "../components/Overview.astro";
import SocialLinks from "../components/SocialLinks.astro";
import About from "../components/About.astro";
import TechStack from "../components/TechStack.astro";
import Experiences from "../components/Experiences.astro";
import Projects from "../components/Projects.astro";
import Separator from "../components/Separator.astro";
import { PORTFOLIO } from "../data";

const { profile, socialLinks, techStack, experiences, projects, sections } = PORTFOLIO;
---

<Layout pageType="ProfilePage">
    <main id="main-content" class="mx-auto max-w-3xl px-2">
        <div class="max-w-screen overflow-x-hidden">
            {sections.profile && <ProfileHeader profile={profile} />}
            {sections.socialLinks && (
                <SocialLinks links={socialLinks.filter((link) => link.placements.includes("home"))} />
            )}
            {(sections.profile || sections.socialLinks) && <Separator />}

            {sections.overview && <Overview profile={profile} />}
            {sections.overview && <Separator />}

            {sections.about && <About profile={profile} />}
            {sections.about && <Separator />}

            {sections.techStack && <TechStack techStack={techStack} />}
            {sections.techStack && <Separator />}

            {sections.experiences && <Experiences experiences={experiences} />}
            {sections.experiences && <Separator />}

            {sections.projects && (
                <Projects
                    projects={projects.items}
                    initialVisible={projects.initialVisible}
                />
            )}

            {sections.projects && <Separator />}
        </div>
    </main>
</Layout>
