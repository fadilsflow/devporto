---
import { render } from "astro:content";
import { getPublishedPosts } from "../../lib/blog";
import Layout from "../../layouts/Layout.astro";
import SiteFooter from "../../components/SiteFooter.astro";

export async function getStaticPaths() {
    const posts = await getPublishedPosts();
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout
    title={post.data.title}
    description={post.data.description}
    pageType="WebPage"
    image={post.data.image}
    bare
>
    <main id="main-content" class="mx-auto max-w-3xl px-2 mt-20">
        <div class="max-w-screen overflow-x-hidden">
            <article class="py-6">
                <header class="mb-10 font-mono border-b pb-5">
                    <h1 class="text-2xl font-medium tracking-tight">
                        {post.data.title}
                    </h1>
                    <div
                        class="mt-5 flex items-center gap-2 text-sm text-foreground/30"
                    >
                        <time datetime={post.data.pubDate.toISOString()}>
                            {
                                post.data.pubDate.toLocaleDateString("en-US", {
                                    year: "numeric",
                                    month: "long",
                                    day: "numeric",
                                })
                            }
                        </time>
                    </div>
                </header>

                <div class="prose prose-neutral dark:prose-invert max-w-none">
                    <Content />
                </div>

                <script>
                    (() => {
                        function addCopyButtons() {
                            const pres = document.querySelectorAll(
                                'pre.astro-code',
                            );
                            for (const pre of pres) {
                                if (pre.querySelector('[data-copy-button]')) continue;

                                const code = pre.querySelector('code');
                                const text = code?.textContent ?? pre.textContent;

                                const btn = document.createElement('button');
                                btn.setAttribute('data-copy-button', '');
                                btn.className =
                                    'absolute top-2 right-2 z-10 inline-flex size-7 items-center justify-center rounded-md border border-border bg-background/80 text-muted-foreground opacity-0 backdrop-blur-sm transition-opacity hover:bg-accent hover:text-accent-foreground focus:opacity-100';

                                // SVG: Clipboard icon
                                btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>`;

                                btn.addEventListener('click', async () => {
                                    try {
                                        await navigator.clipboard.writeText(
                                            text,
                                        );
                                        const original = btn.innerHTML;
                                        btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>`;
                                        btn.classList.add('text-success');
                                        setTimeout(() => {
                                            btn.innerHTML = original;
                                            btn.classList.remove('text-success');
                                        }, 2000);
                                    } catch {
                                        // Clipboard not available
                                    }
                                });

                                pre.style.position = 'relative';

                                // Show button when pre is hovered or focused within
                                pre.addEventListener('mouseenter', () =>
                                    btn.classList.remove('opacity-0'),
                                );
                                pre.addEventListener('mouseleave', () =>
                                    btn.classList.add('opacity-0'),
                                );
                                pre.addEventListener(
                                    'focusin',
                                    () => btn.classList.remove('opacity-0'),
                                );
                                pre.addEventListener(
                                    'focusout',
                                    (e) => {
                                        if (
                                            !pre.contains(e.relatedTarget)
                                        )
                                            btn.classList.add('opacity-0');
                                    },
                                );

                                pre.append(btn);
                            }
                        }

                        if (
                            document.readyState === 'loading'
                        ) {
                            document.addEventListener(
                                'DOMContentLoaded',
                                addCopyButtons,
                            );
                        } else {
                            addCopyButtons();
                        }
                    })();
                </script>
            </article>

            <div class="flex justify-center pt-20">
                <a
                    href="/"
                    class="inline-flex items-center gap-1 text-sm text-foreground/30 transition-colors hover:text-foreground"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                    Back
                </a>
            </div>
            <SiteFooter class:list={"text-foreground/30"} />
        </div>
    </main>
</Layout>
