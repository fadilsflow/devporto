---
import { render } from "astro:content";
import { getPublishedPosts } from "../../lib/blog";
import Layout from "../../layouts/Layout.astro";
import SiteFooter from "../../components/SiteFooter.astro";

export async function getStaticPaths() {
    const posts = await getPublishedPosts();
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout
    title={post.data.title}
    description={post.data.description}
    pageType="WebPage"
    image={post.data.image}
    bare
>
    <main id="main-content" class="mx-auto max-w-3xl px-2 mt-20">
        <div class="max-w-screen overflow-x-hidden">
            <article class="py-6">
                <header class="mb-10 font-mono border-b pb-5">
                    <h1 class="text-2xl font-medium tracking-tight">
                        {post.data.title}
                    </h1>
                    <div
                        class="mt-5 flex items-center gap-2 text-sm text-foreground/30"
                    >
                        <time datetime={post.data.pubDate.toISOString()}>
                            {
                                post.data.pubDate.toLocaleDateString("en-US", {
                                    year: "numeric",
                                    month: "long",
                                    day: "numeric",
                                })
                            }
                        </time>
                    </div>
                </header>

                <div class="prose prose-neutral dark:prose-invert max-w-none">
                    <Content />
                </div>
            </article>

            <div class="flex justify-center pt-20">
                <a
                    href="/"
                    class="inline-flex items-center gap-1 text-sm text-foreground/30 transition-colors hover:text-foreground"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="14"
                        height="14"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <path d="m15 18-6-6 6-6"></path>
                    </svg>
                    Back
                </a>
            </div>
            <SiteFooter class:list={"text-foreground/30"} />
        </div>
    </main>
</Layout>
