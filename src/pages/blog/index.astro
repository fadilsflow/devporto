---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { PORTFOLIO } from "../../data";

const { blogPage } = PORTFOLIO;

const allPosts = await getCollection("blog", ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
);

allPosts.sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<Layout
    title={blogPage.title}
    description={blogPage.seoDescription}
    pageType="WebPage"
>
    <main id="main-content" class="mx-auto max-w-3xl px-2">
        <div class="max-w-screen overflow-x-hidden">
            <div class="pt-2">
                <h1 class="text-3xl font-semibold">{blogPage.title}</h1>
            </div>

            <div class="py-4">
                <p class="font-mono text-sm text-balance text-muted-foreground">
                    {blogPage.description}
                </p>
            </div>

            {allPosts.length === 0 && (
                <p class="text-sm text-muted-foreground">No posts yet.</p>
            )}

            <ul class="divide-y divide-edge">
                {allPosts.map((post) => (
                    <li>
                        <a
                            href={`/blog/${post.id}`}
                            class="flex items-center justify-between py-3 text-sm transition-colors hover:text-foreground/80"
                        >
                            <span class="font-medium">{post.data.title}</span>
                            <time
                                datetime={post.data.pubDate.toISOString()}
                                class="shrink-0 text-muted-foreground"
                            >
                                {post.data.pubDate.toLocaleDateString("en-US", {
                                    year: "numeric",
                                    month: "short",
                                    day: "numeric",
                                })}
                            </time>
                        </a>
                    </li>
                ))}
            </ul>
        </div>
    </main>
</Layout>
