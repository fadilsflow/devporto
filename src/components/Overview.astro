---
import Panel from "./Panel.astro";
import PanelContent from "./PanelContent.astro";
import { PORTFOLIO, type Profile } from "../data";
import { urlToName } from "../lib/utils";

interface Props {
    profile?: Profile;
}

const { profile: configProfile = PORTFOLIO.profile } = Astro.props;
const phone = PORTFOLIO.computed.phone;
const email = PORTFOLIO.computed.email;
const profile = configProfile;

const items: { icon: string; content: string; href?: string }[] = [];

for (const job of profile.jobs) {
    items.push({
        icon: "briefcase",
        content: `${job.title} at ${job.company}`,
        href: job.website,
    });
}
items.push({ icon: "map-pin", content: profile.address.label });
if (phone) {
    items.push({ icon: "phone", content: phone, href: `tel:${phone}` });
}
if (email) {
    items.push({ icon: "mail", content: email, href: `mailto:${email}` });
}
items.push({
    icon: "globe",
    content: urlToName(profile.website),
    href: profile.website,
});
if (profile.pronouns) {
    items.push({ icon: "user", content: profile.pronouns });
}
---

<Panel>
    <h2 class="sr-only">Overview</h2>
    <PanelContent className="space-y-2">
        {
            items.map((item) => (
                <div class="flex items-center gap-2 text-sm">
                    <span
                        class="size-4 shrink-0 text-muted-foreground"
                        aria-hidden
                    >
                        *
                    </span>
                    {item.href ? (
                        <a
                            href={item.href}
                            target={
                                item.href.startsWith("http")
                                    ? "_blank"
                                    : undefined
                            }
                            rel="noopener noreferrer"
                            class="link"
                        >
                            {item.content}
                        </a>
                    ) : (
                        <span>{item.content}</span>
                    )}
                </div>
            ))
        }
    </PanelContent>
</Panel>
