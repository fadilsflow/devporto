---
import { PORTFOLIO, type Profile } from "../data";
import VerifiedIcon from "./VerifiedIcon.astro";

interface Props {
    profile?: Profile;
}

const { profile = PORTFOLIO.profile } = Astro.props;
---

<div class="relative flex">
    <div class="flex flex-1 mt-40">
        <div class="shrink-0 mx-[2px] my-[3px] pb-2">
            <img
                class="size-15 ring-1 ring-border ring-offset-2 ring-offset-background select-none sm:size-20"
                alt={`${profile.displayName}, ${profile.jobTitle} — profile photo`}
                src={profile.avatar}
                width="80"
                height="80"
                fetchpriority="high"
                decoding="async"
            />
        </div>

        <div class="flex flex-1 flex-col">
            <div class="">
                <h1
                    class="flex items-center pl-4 text-2xl font-medium capitalize"
                >
                    {profile.username}
                    {
                        profile.verified && (
                            <VerifiedIcon class="size-[0.6em] ml-2 translate-y-px text-info select-none" />
                        )
                    }
                </h1>

                <div class="h-12 py-1 pl-4 sm:h-auto">
                    <span class="text-foreground/80">
                        {profile.flipSentences[0]}
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>
