---
import Panel from "./Panel.astro";
import PanelHeader from "./PanelHeader.astro";
import PanelTitle from "./PanelTitle.astro";
import { PORTFOLIO, type Project } from "../data/portfolio";
import { md } from "../lib/utils";

interface Props {
    projects?: Project[];
    initialVisible?: number;
}

const {
    projects = PORTFOLIO.projects.items,
    initialVisible = PORTFOLIO.projects.initialVisible,
} = Astro.props;
---

<Panel id="projects">
    <PanelHeader>
        <PanelTitle>
            Projects
            <sup
                class="ml-1 font-mono text-xs text-muted-foreground select-none"
            >
                ({projects.length})
            </sup>
        </PanelTitle>
    </PanelHeader>

    <div>
        {
            projects.map((project, index) => {
                const isOngoing = !project.period.end;
                const isHidden = index >= initialVisible;
                return (
                    <div
                        class:list={[
                            "border-b border-edge last:border-b-0",
                            isHidden && "hidden",
                        ]}
                        data-project-item={isHidden ? "extra" : "visible"}
                    >
                        <div
                            class="flex w-full items-center hover:bg-accent2 cursor-pointer group/project"
                            data-collapse-trigger={`project-${index}`}
                            aria-expanded={
                                project.isExpanded ? "true" : "false"
                            }
                            role="button"
                            tabindex="0"
                        >
                            {project.logo ? (
                                <img
                                    src={project.logo}
                                    alt={`${project.title} logo`}
                                    width="32"
                                    height="32"
                                    class="mx-4 size-6 shrink-0 select-none"
                                    loading="lazy"
                                    decoding="async"
                                />
                            ) : (
                                <div class="mx-4 flex size-6 shrink-0 items-center justify-center text-muted-foreground select-none">
                                    ◆
                                </div>
                            )}
                            <div class="flex-1 border-l border-dashed border-edge">
                                <div class="flex w-full items-center gap-4 p-4 pr-2 text-left">
                                    <div class="flex-1">
                                        <h3 class="mb-1 leading-snug font-medium text-balance">
                                            {project.title}
                                        </h3>
                                        <p class="text-sm text-muted-foreground">
                                            {project.period.start}
                                            <span class="font-mono"> — </span>
                                            {isOngoing
                                                ? "Present"
                                                : project.period.end}
                                        </p>
                                    </div>
                                    <a
                                        href={project.link}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="text-muted-foreground hover:text-foreground"
                                        aria-label={`Open ${project.title} project`}
                                        onclick="event.stopPropagation()"
                                    >
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="16"
                                            height="16"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                        >
                                            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                                            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
                                        </svg>
                                    </a>
                                    <span class="text-muted-foreground">
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="16"
                                            height="16"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            class="hidden group-aria-expanded/project:block"
                                        >
                                            <path d="m7 20 5-5 5 5" />
                                            <path d="m7 4 5 5 5-5" />
                                        </svg>
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="16"
                                            height="16"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            class="block group-aria-expanded/project:hidden"
                                        >
                                            <path d="m7 15 5 5 5-5" />
                                            <path d="m7 9 5-5 5 5" />
                                        </svg>
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div
                            class="overflow-hidden transition-all duration-300"
                            data-collapse-content={`project-${index}`}
                            style={project.isExpanded ? "" : "max-height: 0;"}
                        >
                            <div class="space-y-4 border-t border-dashed border-edge p-4 pl-14">
                                {project.description && (
                                    <div
                                        class="prose prose-sm prose-zinc dark:prose-invert max-w-none"
                                        set:html={md(project.description)}
                                    />
                                )}
                                {project.skills.length > 0 && (
                                    <ul class="flex flex-wrap gap-1.5">
                                        {project.skills.map((skill) => (
                                            <li class="inline-flex items-center rounded-md border border-border bg-secondary px-2 py-0.5 text-xs text-secondary-foreground">
                                                {skill}
                                            </li>
                                        ))}
                                    </ul>
                                )}
                            </div>
                        </div>
                    </div>
                );
            })
        }

        {
            projects.length > initialVisible && (
                <div class="flex h-12 items-center justify-center pb-px">
                    <button
                        id="projects-show-more"
                        class="group/showmore inline-flex items-center gap-2  border border-edge px-3 py-1.5 text-sm font-medium hover:bg-accent transition-colors"
                        aria-expanded="false"
                    >
                        <span class="block group-aria-expanded/showmore:hidden">
                            Show More
                        </span>
                        <span class="hidden group-aria-expanded/showmore:block">
                            Show Less
                        </span>
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="transition-transform group-aria-expanded/showmore:rotate-180"
                        >
                            <path d="m6 9 6 6 6-6" />
                        </svg>
                    </button>
                </div>
            )
        }
    </div>
</Panel>

<script>
    function initProjectsShowMore() {
        const btn = document.getElementById("projects-show-more");
        if (!btn) return;

        const handleClick = () => {
            const isExpanded = btn.getAttribute("aria-expanded") === "true";
            const extras = document.querySelectorAll(
                '[data-project-item="extra"]',
            );

            if (isExpanded) {
                btn.setAttribute("aria-expanded", "false");
                extras.forEach((el) => el.classList.add("hidden"));
            } else {
                btn.setAttribute("aria-expanded", "true");
                extras.forEach((el) => el.classList.remove("hidden"));
            }
        };

        btn.removeEventListener("click", handleClick);
        btn.addEventListener("click", handleClick);
    }

    initProjectsShowMore();
    document.addEventListener("astro:after-swap", initProjectsShowMore);
</script>
