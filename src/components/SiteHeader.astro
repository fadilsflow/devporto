---
import ThemeToggle from "./ThemeToggle.astro";
import { PORTFOLIO } from "../data";

const navItems = PORTFOLIO.navigation.filter((item) => item.enabled !== false);
const currentPath = Astro.url.pathname;
---

<header
    class="sticky top-0 z-50 hidden max-w-screen overflow-x-hidden bg-background px-2 sm:block"
>
    <div
        class="mx-auto flex h-12 items-center justify-between gap-2 px-2 sm:gap-4 max-w-3xl"
    >
        <a
            href="/"
            class="flex items-center shrink-0"
            aria-label={`Home — ${PORTFOLIO.profile.displayName}`}
        >
            <span class="sr-only">Home</span>
            {
                PORTFOLIO.site.logo?.src && (
                    <img
                        src={PORTFOLIO.site.logo.src}
                        alt={
                            PORTFOLIO.site.logo.alt ??
                            `${PORTFOLIO.site.name} logo`
                        }
                        class="h-7 w-auto"
                        width="64"
                        height="32"
                    />
                )
            }
        </a>

        <div class="flex-1"></div>

        <nav class="hidden sm:flex items-center gap-6" aria-label="Primary">
            {
                navItems.map((item) => (
                    <a
                        href={item.href}
                        aria-current={
                            currentPath === item.href ? "page" : undefined
                        }
                        class:list={[
                            "text-sm font-medium transition-colors hover:text-foreground",
                            currentPath === item.href
                                ? "text-foreground"
                                : "text-muted-foreground",
                        ]}
                    >
                        {item.title}
                    </a>
                ))
            }
        </nav>

        <div class="flex items-center gap-2">
            <ThemeToggle />
        </div>
    </div>
</header>

<nav
    class="fixed inset-x-0 bottom-0 z-50 border-t border-edge bg-background px-3 pb-[calc(0.75rem+env(safe-area-inset-bottom))] pt-2 sm:hidden"
    aria-label="Primary"
>
    <div class="mx-auto grid max-w-md grid-cols-4 items-end gap-1">
        {
            navItems.map((item) => {
                const isActive = currentPath === item.href;

                return (
                    <a
                        href={item.href}
                        aria-current={isActive ? "page" : undefined}
                        class:list={[
                            "flex min-h-14 flex-col items-center justify-center gap-1 px-2 text-[11px] font-medium leading-none transition-colors",
                            isActive
                                ? "bg-accent text-foreground"
                                : "text-muted-foreground hover:bg-accent/70 hover:text-foreground",
                        ]}
                    >
                        <svg
                            class="size-5"
                            xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            aria-hidden="true"
                        >
                            <path d={item.icon} />
                        </svg>
                    </a>
                );
            })
        }

        <ThemeToggle
            id="mobile-theme-toggle"
            class="min-h-14 flex-col gap-1 bg-transparent px-2 text-[11px] leading-none text-muted-foreground hover:bg-accent/70 hover:text-foreground"
        />
    </div>
</nav>
