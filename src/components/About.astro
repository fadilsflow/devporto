---
import Panel from "./Panel.astro";
import PanelContent from "./PanelContent.astro";
import PanelHeader from "./PanelHeader.astro";
import PanelTitle from "./PanelTitle.astro";
import { PORTFOLIO, type Profile } from "../data";
import { md } from "../lib/utils";

interface Props {
    profile?: Profile;
}

const { profile = PORTFOLIO.profile } = Astro.props;
const html = md(profile.about);
---

<Panel id="about">
  <PanelHeader>
    <PanelTitle>About</PanelTitle>
  </PanelHeader>

  <PanelContent>
    <div class="prose prose-zinc dark:prose-invert max-w-none" set:html={html} />
  </PanelContent>
</Panel>
