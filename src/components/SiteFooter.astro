---
import { PORTFOLIO } from "../data";

const { footer, profile, site } = PORTFOLIO;
const siteUrl =
    Astro.site?.toString().replace(/\/$/, "") ?? site.url.replace(/\/$/, "");
const year = new Date().getFullYear();
---

<footer class="py-20 flex justify-center text-center">
    <p
        class="flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-foreground/30"
    >
        <span>© {year}</span>
        <span aria-hidden="true">/</span>
        {
            footer.builtByHref ? (
                <a
                    href={footer.builtByHref}
                    target="_blank"
                    rel="noopener noreferrer me"
                >
                    {profile.displayName}
                </a>
            ) : (
                <span class="text-foreground/30">{profile.displayName}</span>
            )
        }
        <span aria-hidden="true">/</span>
        <a
            href={`${siteUrl}/llms.txt`}
            target="_blank"
            rel="noopener noreferrer"
        >
            llms.txt
        </a>
        <span aria-hidden="true">/</span>
        <a
            href={`${siteUrl}/rss.xml`}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="RSS feed"
            class={`inline-flex items-center`}
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
            >
                <path d="M4 11a9 9 0 0 1 9 9"></path>
                <path d="M4 4a16 16 0 0 1 16 16"></path>
                <circle cx="5" cy="19" r="1"></circle>
            </svg>
        </a>
    </p>
</footer>
