---
import Panel from "./Panel.astro";
import PanelHeader from "./PanelHeader.astro";
import PanelTitle from "./PanelTitle.astro";
import { PORTFOLIO, type Experience } from "../data/portfolio";
import { md } from "../lib/utils";

interface Props {
    experiences?: Experience[];
}

const { experiences = PORTFOLIO.experiences } = Astro.props;

function formatPeriod(p: { start: string; end?: string }) {
    return `${p.start} — ${p.end ?? "Present"}`;
}
---

<Panel id="experience">
    <PanelHeader>
        <PanelTitle>Experience</PanelTitle>
    </PanelHeader>

    <div class="pr-2 pl-4">
        {
            experiences.map((exp) => (
                <div class="screen-line-after space-y-4 py-4">
                    <div class="flex items-center gap-3">
                        <div class="flex size-6 shrink-0 items-center justify-center select-none">
                            {exp.companyLogo ? (
                                <img
                                    src={exp.companyLogo}
                                    alt={`${exp.companyName} logo`}
                                    width="24"
                                    height="24"
                                    class="rounded-full"
                                    loading="lazy"
                                    decoding="async"
                                />
                            ) : (
                                <span class="flex size-2 rounded-full bg-zinc-300 dark:bg-zinc-600" />
                            )}
                        </div>

                        <h3 class="text-lg leading-snug font-medium">
                            {exp.companyName}
                        </h3>

                        {exp.isCurrentEmployer && (
                            <span class="relative flex items-center justify-center">
                                <span class="absolute inline-flex size-3 animate-ping rounded-full bg-info opacity-50" />
                                <span class="relative inline-flex size-2 rounded-full bg-info" />
                                <span class="sr-only">Current Employer</span>
                            </span>
                        )}
                    </div>

                    <div
                        class:list={[
                            "relative space-y-4",
                            exp.positions.length > 1 &&
                                "before:absolute before:left-3 before:top-8 before:bottom-8 before:w-px before:bg-border",
                        ]}
                    >
                        {exp.positions.map((pos, index) => (
                            <div class="relative flex gap-2">
                                <button
                                    class="bg-muted rounded-md flex size-6 shrink-0 items-center justify-center text-muted-foreground hover:text-foreground transition-colors mt-2"
                                    data-collapse-icon={`${exp.id}-${index}`}
                                    aria-label="Toggle details"
                                >
                                    {pos.icon === "education" ? (
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="16"
                                            height="16"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                        >
                                            <path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z" />
                                            <path d="M22 10v6" />
                                            <path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5" />
                                        </svg>
                                    ) : pos.icon === "design" ? (
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="16"
                                            height="16"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                        >
                                            <path d="m12.99 6.74 1.93 3.44" />
                                            <path d="M19.136 12a10 10 0 0 1-14.271 0" />
                                            <path d="m21 21-2.16-3.84" />
                                            <path d="m3 21 8.02-14.26" />
                                            <circle cx="12" cy="5" r="2" />
                                        </svg>
                                    ) : (
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="16"
                                            height="16"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                        >
                                            <path d="m18 16 4-4-4-4" />
                                            <path d="m6 8-4 4 4 4" />
                                            <path d="m14.5 4-5 16" />
                                        </svg>
                                    )}
                                </button>
                                <div class="flex-1">
                                    <button
                                        class="w-full text-left space-y-1 group px-3 py-2 rounded-md hover:bg-muted transition-colors"
                                        data-collapse-trigger={`${exp.id}-${index}`}
                                        aria-expanded="false"
                                    >
                                        <div class="flex items-center justify-between gap-2">
                                            <h4 class="font-medium leading-snug">
                                                {pos.title}
                                            </h4>
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                width="16"
                                                height="16"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="2"
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                class="text-muted-foreground transition-transform shrink-0 hidden group-aria-expanded:block"
                                            >
                                                <path d="m7 20 5-5 5 5" />
                                                <path d="m7 4 5 5 5-5" />
                                            </svg>
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                width="16"
                                                height="16"
                                                viewBox="0 0 24 24"
                                                fill="none"
                                                stroke="currentColor"
                                                stroke-width="2"
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                class="text-muted-foreground transition-transform shrink-0 block group-aria-expanded:hidden"
                                            >
                                                <path d="m7 15 5 5 5-5" />
                                                <path d="m7 9 5-5 5 5" />
                                            </svg>
                                        </div>
                                        <p class="text-sm text-muted-foreground">
                                            {formatPeriod(pos.employmentPeriod)}
                                            {pos.employmentType && (
                                                <span>
                                                    {" "}
                                                    · {pos.employmentType}
                                                </span>
                                            )}
                                        </p>
                                    </button>
                                    <div
                                        class="overflow-hidden transition-all duration-300"
                                        data-collapse-content={`${exp.id}-${index}`}
                                        style="max-height: 0;"
                                    >
                                        {pos.description && (
                                            <div
                                                class="prose prose-sm prose-zinc dark:prose-invert mt-2 px-3 max-w-none"
                                                set:html={md(pos.description)}
                                            />
                                        )}
                                        {pos.skills &&
                                            pos.skills.length > 0 && (
                                                <ul class="mt-2 px-3 flex flex-wrap gap-1.5">
                                                    {pos.skills.map((skill) => (
                                                        <li class="inline-flex items-center rounded-md border border-border bg-secondary px-2 py-0.5 text-xs text-secondary-foreground">
                                                            {skill}
                                                        </li>
                                                    ))}
                                                </ul>
                                            )}
                                    </div>
                                </div>
                            </div>
                        ))}
                    </div>
                </div>
            ))
        }
    </div>
</Panel>

<script>
    function initCollapseToggles() {
        const triggers = document.querySelectorAll("[data-collapse-trigger]");

        triggers.forEach((trigger) => {
            const id = trigger.getAttribute("data-collapse-trigger");
            const content = document.querySelector(
                `[data-collapse-content="${id}"]`,
            ) as HTMLElement;

            if (!content) return;

            const handleClick = () => {
                const isExpanded =
                    trigger.getAttribute("aria-expanded") === "true";

                if (isExpanded) {
                    trigger.setAttribute("aria-expanded", "false");
                    content.style.maxHeight = "0";
                } else {
                    trigger.setAttribute("aria-expanded", "true");
                    content.style.maxHeight = content.scrollHeight + "px";
                }
            };

            trigger.removeEventListener("click", handleClick);
            trigger.addEventListener("click", handleClick);
        });
    }

    initCollapseToggles();
    document.addEventListener("astro:after-swap", initCollapseToggles);
</script>
